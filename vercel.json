{
  "buildCommand": "node quartz/bootstrap-cli.mjs build",
  "outputDirectory": "public",
  "installCommand": "npm install --force",
  "regions": ["lhr1"],
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=86400"
        }
      ]
    }
  ]
}
