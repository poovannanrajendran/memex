# --- Gemini API ---
GEMINI_API_KEY=your_api_key_here
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_SYNTHESIS_MODEL=gemini-2.5-pro
GEMINI_FALLBACK_MODEL=gemini-2.5-flash

# --- Automation Engine ---
POSTGRES_URL=postgresql://dbuser:dbuser@192.168.1.30:5432/memex
POLL_INTERVAL_MINUTES=15

# --- Runner API ---
RUNNER_API_PORT=8000
RUNNER_API_SECRET=fad34ecf58ddccc88804a229715dfe6795d348fd513514bd54afa34c5bca91de

# --- OpenClaw Integration ---
# n8n webhook URL for incremental Qdrant sync
N8N_MEMEX_SYNC_URL=http://192.168.1.30:5678/webhook/memex-ingest

# Qdrant configuration
QDRANT_HOST=http://192.168.1.20:6333
QDRANT_API_KEY=your_qdrant_api_key_here

# Notifications
OPENCLAW_NOTIFY_ENABLED=true
